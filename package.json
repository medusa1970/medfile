{
  "name": "medfile-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace @medfile/web",
    "dev:api": "npm run build:types && npm run start:dev --workspace @medfile/api",
    "setup:local": "node scripts/init-local-env.mjs",
    "env:sync": "node scripts/sync-local-env.mjs",
    "env:check": "node scripts/check-local-env.mjs",
    "build:types": "npm run build --workspace @medfile/types",
    "build:api": "npm run build:types && npm run build --workspace @medfile/api",
    "build:web": "npm run build:types && npm run build --workspace @medfile/web",
    "build": "npm run build:types && npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "delete-account": "node scripts/delete-account-by-email.mjs",
    "reset:local-clients": "node scripts/reset-local-clients.mjs --yes",
    "reset:remote-clients": "node scripts/reset-local-clients.mjs --remote --yes"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.24"
  }
}
