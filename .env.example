NODE_ENV=development

# Web
NUXT_PUBLIC_APP_NAME=medfile
NUXT_PUBLIC_APP_URL=http://localhost:3100
NUXT_PUBLIC_API_URL=http://localhost:4000

# API
API_PORT=4000
WEB_ORIGIN=http://localhost:3100,http://127.0.0.1:3100
MONGODB_URI=mongodb://localhost:27017/medfile_dev
MONGODB_URL=mongodb://localhost:27017/medfile_dev
LOCAL_MONGODB_URI=mongodb://localhost:27017/medfile_dev
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_SECRET=change-me-too

# Email (Hostinger en prod; opcional en dev — sin SMTP imprime OTP en consola)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Medfile <noreply@medfile.my>
APP_PUBLIC_URL=http://localhost:3100

# Storage compatible con S3/R2
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=medfile-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Payments (Mercado Pago Bolivia)
PAYMENTS_PROVIDER=mock
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# Webhook produccion: https://api.tudominio.com/api/webhooks/mercadopago
