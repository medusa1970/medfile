# Plantilla para desarrollo local espejo de Railway (produccion).
# 1) Copia este archivo a .env.local en la raiz del repo (gitignored).
# 2) Completa los valores desde Railway → servicio medfile-api → Variables.
# 3) Reinicia API y Web tras cambiar variables.
#
#   npm run setup:local
#   npm run env:check
#   Medfile: Dev (API + Web)
#
# ADVERTENCIA: si usas la misma MONGODB_URI que produccion, los cambios locales
# afectan datos reales. No ejecutes scripts destructivos en local.

NODE_ENV=development

# --- Web (Nuxt en http://localhost:3100) ---
NUXT_PUBLIC_APP_NAME=medfile
NUXT_PUBLIC_APP_URL=http://localhost:3100
NUXT_PUBLIC_API_URL=http://localhost:4000

# --- API (Nest en http://localhost:4000) ---
API_PORT=4000
WEB_ORIGIN=http://localhost:3100,http://127.0.0.1:3100
APP_PUBLIC_URL=http://localhost:3100

# MongoDB Atlas — pegar la misma URI que Railway (medfile-api → MONGODB_URI)
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/medfile?retryWrites=true&w=majority
MONGODB_URL=
LOCAL_MONGODB_URI=

# JWT — puede ser el mismo secreto de Railway o uno local solo para dev
JWT_ACCESS_SECRET=genera-o-pega-desde-railway-min-32-chars
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_SECRET=opcional-local

# Correo — Brevo (recomendado, igual que produccion)
BREVO_API_KEY=xkeysib-pega-desde-railway
EMAIL_FROM=Medfile <noreply@medfile.my>

# Alternativa Resend (no configures ambos a la vez; Brevo tiene prioridad si RESEND_API_KEY existe)
# RESEND_API_KEY=
# RESEND_FROM=Medfile <noreply@medfile.my>

# SMTP (solo util en local si pruebas nodemailer; Railway Hobby lo bloquea)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Medfile <noreply@medfile.my>

# Storage R2/S3 — pegar desde Railway si subes documentos en local
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Pagos — mock en local salvo que pruebes checkout real
PAYMENTS_PROVIDER=mock
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
