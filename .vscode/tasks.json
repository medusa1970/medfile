{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Medfile: API (backend)",
      "type": "shell",
      "command": "npm run dev:api",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "medfile-dev",
        "showReuseMessage": false
      },
      "problemMatcher": {
        "owner": "medfile-api",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation",
          "endsPattern": "Nest application successfully started|Error:"
        }
      }
    },
    {
      "label": "Medfile: Web (Nuxt)",
      "type": "shell",
      "command": "npm run dev:web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "medfile-dev",
        "showReuseMessage": false
      },
      "problemMatcher": {
        "owner": "medfile-web",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Medfile: Dev (API + Web)",
      "dependsOn": ["Medfile: API (backend)", "Medfile: Web (Nuxt)"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
